{
  "name": "federation-serverless",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "wrangler check",
    "types": "wrangler types",
    "deploy": "wrangler deploy",
    "schema": "wrangler d1 execute federation-db --remote --file=src/schema.sql",
    "migrate:watchtower": "wrangler d1 execute federation-db --remote --file=src/migrations/0001_watchtower_enforcement.sql",
    "migrate:control-loop": "wrangler d1 execute federation-db --remote --file=src/migrations/0002_watchtower_control_loop.sql",
    "migrate:access-gateway": "wrangler d1 execute federation-db --remote --file=src/migrations/0003_watchtower_access_gateway.sql",
    "migrate:lifecycle": "wrangler d1 execute federation-db --remote --file=src/migrations/0004_federation_lifecycle.sql",
    "migrate:management": "wrangler d1 execute federation-db --remote --file=src/migrations/0005_management.sql",
    "migrate:alert-sink": "wrangler d1 execute federation-db --remote --file=src/migrations/0006_alert_webhook_receipts.sql",
    "migrate:audit-chain-integrity": "wrangler d1 execute federation-db --remote --file=src/migrations/0008_audit_chain_integrity.sql",
    "migrate:speech-lines-drop-fk": "wrangler d1 execute federation-db --remote --file=src/migrations/0009_speech_lines_drop_federation_fk.sql",
    "test": "node --experimental-strip-types --test src/*.test.ts",
    "security:socket": "socket scan create --report --no-interactive .",
    "security:socket:dry-run": "socket scan create --dry-run --no-interactive ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "socket": "^1.1.143",
    "wrangler": "^4.0.0"
  },
  "allowScripts": {
    "workerd@1.20260714.1": true,
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "core-js-pure@3.49.0": true
  }
}
