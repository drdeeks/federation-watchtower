*.tsbuildinfo
tsconfig.tsbuildinfo

# Babel
.babelrc
.babelrc.js
.babelrc.cjs
.babelrc.mjs

# ES Build
esbuild/*.js
esbuild/*.mjs

# ============================================================
# CLOUDFLARE WORKERS SPECIFIC
# ============================================================
# Local development state
.wrangler/
worker-configuration.d.ts
worker-configuration.d.ts.map

# D1 local database files
*.sqlite
*.sqlite-shm
*.sqlite-wal
d1/
.d1/

# R2 local storage
.r2/
miniflare-*/

# Queue local state
.queue/

# ============================================================
# RELEASE & PACKAGING
# ============================================================
# Release bundles (keep intentional releases in release store)
federation-*.tar.gz
*.tar.gz
*.tgz
packages/*/*.tgz
packages/*/*.tar.gz
dist-*/
release-*/

# npm pack output
*.npm

# ============================================================
# DOCUMENTATION & ASSETS (LARGE/GENERATED)
# ============================================================
# Skills reference material (large, not part of deploy)
skills-reference/

# Brand assets (original sources, not generated)
brand/assets/
brand/raw/
brand/source/

# Legacy sprite sheets (widget now uses procedural generation)
source/federation-tv-widget/public/sprites/
source/federation-tv-widget/public/sprites/**/*

# Generated documentation
docs/generated/
docs/api/
*.mdx

# ============================================================
# LOCAL SCRIPTS & TOOLS
# ============================================================
# One-off debug/verification scripts with hardcoded dev ports/tokens
/manage-drive.mjs
/scripts/debug-*
/tools/dev-*

# ============================================================
# SECURITY & VULNERABILITY SCANS
# ============================================================
# Socket security scans
socket/
.socket/
*.socket

# Snyk
.snyk

# npm audit
npm-audit.json

# Dependabot
.dependabot/

# ============================================================
# CI/CD & AUTOMATION
# ============================================================
# GitHub Actions
.github/workflows/local-*

# CircleCI
.circleci/local-*

# Travis CI
.travis/local-*

# Jenkins
jenkins/

# ============================================================
# DOCKER & CONTAINERS
# ============================================================
# Docker local overrides
docker-compose.override.yml
docker-compose.local.yml
*.docker.local

# Container volumes
.docker/

# ============================================================
# TESTING & QUALITY
# ============================================================
# Playwright
playwright-report/
test-results/
*.playwright/

# Jest
jest-results/

# Mocha
mocha-output/

# Vitest
vitest-results/

# ============================================================
# PERFORMANCE & PROFILING
# ============================================================
# Chrome profiles
*.cpuprofile
*.heapsnapshot

# Node profiles
*.log
profile/

# ============================================================
# MISCELLANEOUS
# ============================================================
# Patch files
*.patch
*.diff

# Backup files
*.bak
*.backup
*.old

# Temporary files
*.temp
*.tmp
*.swp
*.swo

# Lock files (keep package-lock.json, yarn.lock, pnpm-lock.yaml)
# but ignore others
Pipfile.lock
Gemfile.lock
composer.lock
poetry.lock
Cargo.lock

# ============================================================
# END OF .gitignore
# ============================================================
# Repository is clean, modular, and production-ready
# ============================================================
