# ============================================================
# FEDERATION WATCHTOWER — ROBUST .gitignore
# Clean, modular, production-ready repository
# ============================================================

# ============================================================
# PACKAGE MANAGER & DEPENDENCIES
# ============================================================
node_modules/
.pnp.*
.pnp.js
.yarn/
.yarn-integrity
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.npmrc
.yarnrc
.pnpm-store/
.bower_components/
jspm_packages/

# ============================================================
# LOCAL SECRETS & CONFIGURATION (CRITICAL)
# ============================================================
# Never commit secrets, tokens, or credentials
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Cloudflare Worker local config
.dev.vars
.dev.vars.*
!.dev.vars.example
source/federation-serverless/.dev.vars
source/federation-serverless/.dev.vars.*

# Wrangler local state (DO NOT COMMIT)
.wrangler/
wrangler.toml.local
*.wrangler.local

# Cloudflare credentials
~/.wrangler/
.cloudflare/

# ============================================================
# BUILD, TEST, & RUNTIME OUTPUT
# ============================================================
# Build artifacts
dist/
build/
out/
.next/
.nuxt/
.output/

# Test coverage
coverage/
.nyc_output/
*.lcov
cover/

# Cache directories
.cache/
.turbo/
.parcel-cache/
.eslintcache
.stylelintcache
tsconfig.tsbuildinfo
*.tsbuildinfo

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime artifacts
*.pid
*.seed
*.pid.lock
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp

