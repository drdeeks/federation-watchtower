*.swp
*.swo
*.swn
*.bak
*.un~
Session.vim
Sessionx.vim
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace
*.sublime-session
*.sublime-settings

# Atom
.atom/

# NeoVim
.localhistory
*.localhistory

